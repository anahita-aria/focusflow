# FocusFlow — cloud sync (optional, Phase 2)
#
# Copy this file to `.env` and paste the two values from your Supabase project
# (Project Settings → API). The app runs fully local-only until both are set.
#
# Use the PUBLIC anon key — never the service_role / secret key.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
